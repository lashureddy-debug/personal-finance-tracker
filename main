import pandas as pd
import csv
from datetime import datetime
from data_entry import get_amount, get_category, get_date, get_description
import matplotlib.pyplot as plt

class CSV:
    CSV_FILE="finance_data.csv"
    COLUMNS=["date", "amount", "category", "description"]
    FORMAT="%d-%m-%Y"

    @classmethod
    def create_csv(cls):
        try:
            pd.read_csv(cls.CSV_FILE)
        except FileNotFoundError:
            df=pd.DataFrame(columns=cls.COLUMNS) #created pandas dataframe
            df.to_csv(cls.CSV_FILE,index=False) #converted dataframe into csv, False means it will be a named file

    @classmethod
    def add_entry(cls,date,amount,category,description): #takes care of adding new line to csv file
        new_entry={
            "date":date,
            "amount":amount,
            "category":category,
            "description":description
        }
        with open(cls.CSV_FILE,"a",newline="") as csvfile:
            writer=csv.DictWriter(csvfile, fieldnames=cls.COLUMNS)
            writer.writerow(new_entry)
        print("Enter added successfully")
    
    @classmethod
    def get_transactions(cls,start_date,end_date):
        df=pd.read_csv(cls.CSV_FILE)
        df["date"]=pd.to_datetime(df["date"],format=CSV.FORMAT)
        start_date=datetime.strptime(start_date,CSV.FORMAT)
        end_date=datetime.strptime(end_date,CSV.FORMAT)

        mask=(df["date"]>=start_date) & (df["date"]<=end_date)
        filtered_df=df.loc[mask]
        
        if filtered_df.empty:
            print("No transactions in give date range")
        else:
            print(f"Transactions from {start_date.strftime(CSV.FORMAT)} to {end_date.strftime(CSV.FORMAT)}") #header
            print(filtered_df.to_string(index=False, formatters={"date": lambda x: x.strftime(CSV.FORMAT)})) #lambda function called on every object in date column
            
            total_income=filtered_df[filtered_df["category"]=="Income"]["amount"].sum()
            total_expense=filtered_df[filtered_df["category"]=="Expense"]["amount"].sum()
            print("\nSummary:")
            print(f"Total Income: ${total_income:.2f}")
            print(f"Total Expense: ${total_expense:.2f}")
            print(f"Net Savings: ${(total_income-total_expense):.2f}")

        return filtered_df #can create graph with this later

def add(): #adds user's input to csv file
    CSV.create_csv() 
    date=get_date("Enter date of transaction (dd-mm-yyyy) or enter for today's date: ") 
    amount=get_amount()
    category=get_category()
    description=get_description()
    CSV.add_entry(date,amount,category,description)

def plot_transaction(df):
    df_copy=df.copy()
    df_copy.set_index("date",inplace=True)
    income_df=(
        df_copy[df_copy["category"]=="Income"]
        .resample("D")
        .sum()
        .fillna(0)
    )

    expense_df=(
        df_copy[df_copy["category"]=="Expense"]
        .resample("D")
        .sum()
        .fillna(0)
    )

    plt.figure(figsize=(10,5))

    plt.plot(income_df.index, income_df["amount"], label="Income", color="g") #income_df.index (x coord), income_df["amount"] (y-coord)
    plt.plot(expense_df.index, expense_df["amount"], label="Expense", color="r") #income_df.index (x coord), income_df["amount"] (y-coord)

    plt.xlabel("Date")
    plt.ylabel("Amount")
    plt.title("Income and Expense Over Time")
    plt.legend()
    plt.grid(True)
    plt.show()



def main():
    while True:
        print("\n1. Add a new transaction")
        print("2. View transactions and summary within date range")
        print("3. Exit")
        option=input("Enter an option (1-3): ")

        if option=="1":
            add()
        elif option=="2":
            start=get_date("Enter start date (dd-mm-yyyy): ")
            end=get_date("Enter end date (dd-mm-yyyy): ")
            df=CSV.get_transactions(start,end) #converting to df to use later for graphing
            if(input("Do you want to see a plot (y/n)? ").lower()) == "y":
                plot_transaction(df)
        elif option=="3":
            print("Exiting...")
            break
        else:
            print("Invalid selection. Re-enter 1-3.")


if __name__=="__main__":
    main()
